# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vehicle_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vehicle_db

# Backend Configuration
DEBUG=True
SQL_ECHO=False
UPLOAD_DIR=uploads

# Frontend Configuration
BACKEND_URL=http://backend:8000

# For Railway Deployment
# DATABASE_URL will be provided by Railway PostgreSQL plugin
# Update BACKEND_URL to your Railway backend service URL
# BACKEND_URL=https://your-backend-service-name.up.railway.app
